# Security
SECRET_KEY=change-me-in-production

# Database
# Dev: SQLite file. Prod: Railway-provided Postgres URL.
DATABASE_URL=sqlite:///./store.db

# Frontend connection
# Dev: http://localhost:8888
# Prod: https://your-netlify-domain.netlify.app (or custom domain)
FRONTEND_URL=http://localhost:8888
CORS_ORIGINS=http://localhost:8888,http://localhost:5173

# Stripe (backend uses these only for server-side calls; frontend has its own publishable key)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Google OAuth
# The redirect URI must EXACTLY match an entry in Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Client → Authorized redirect URIs).
# Dev:  http://localhost:8000/api/auth/google/callback
# Prod: https://your-railway-backend-domain/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=BALM Store
